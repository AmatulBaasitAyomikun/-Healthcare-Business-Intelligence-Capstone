    <dashboard name='Hospital Performance Analytics' type='storyboard'>
      <style>
        <style-rule element='story-description'>
          <format attr='font-style' id='story-description_9' value='normal' />
          <format attr='font-weight' id='story-description_9' value='normal' />
          <format attr='text-decoration' id='story-description_9' value='none' />
          <format attr='font-style' id='story-description_13' value='normal' />
          <format attr='font-weight' id='story-description_13' value='normal' />
          <format attr='text-decoration' id='story-description_13' value='none' />
          <format attr='font-style' id='story-description_20' value='normal' />
          <format attr='font-weight' id='story-description_20' value='normal' />
          <format attr='text-decoration' id='story-description_20' value='none' />
        </style-rule>
      </style>
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98014' id='1' param='vert' removable='false' type-v2='layout-flow' w='99002' x='499' y='993'>
            <zone h='6203' id='3' type-v2='title' w='99002' x='499' y='993' />
            <zone h='9801' id='4' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99002' x='499' y='7196' />
            <zone h='82010' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99002' x='499' y='16997'>
              <flipboard active-id='13' nav-type='arrowonly' show-nav-arrows='true'>
                <story-points>
                  <story-point captured-sheet='' id='2' />
                  <story-point captured-sheet='' id='22' />
                  <story-point captured-sheet='' id='4' />
                  <story-point captured-sheet='Dashboard 1' id='5' />
                  <story-point captured-sheet='' id='8' />
                  <story-point captured-sheet='' id='9' />
                  <story-point captured-sheet='' id='10' />
                  <story-point captured-sheet='Dashboard 2' id='13' />
