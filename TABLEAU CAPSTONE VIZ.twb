    <worksheet name='Diagnoses vs ALOS'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#1b4f72' fontname='Tableau Semibold' fontsize='11'>High-Volume Diagnoses Cluster Above the 4.9-Day Hospital ALOS, Signalling Compounded Resource Strain</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='encounters+ (Hospital_data)' name='federated.138uqpt06ih0p21aca9cz020fql2' />
          </datasources>
          <datasource-dependencies datasource='federated.138uqpt06ih0p21aca9cz020fql2'>
            <column caption='24 month window' datatype='boolean' name='[Calculation_0343332865441792]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[start_date] &gt;= #2023-01-01# AND [start_date] &lt;= #2024-12-31#' />
            </column>
            <column caption='ALOS' datatype='real' name='[Calculation_0343332869070849]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(DATEDIFF(&apos;day&apos;, [start_date], [stop_date]))' />
            </column>
            <column-instance column='[encounter_id]' derivation='CountD' name='[ctd:encounter_id:qk]' pivot='key' type='quantitative' />
            <column caption='Diagnosis' datatype='string' name='[diagnosis]' role='dimension' type='nominal' />
            <column caption='Encounter Id' datatype='string' name='[encounter_id]' role='dimension' type='nominal' />
