      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='encounters+ (Hospital_data)' name='federated.138uqpt06ih0p21aca9cz020fql2' />
          </datasources>
          <datasource-dependencies datasource='federated.138uqpt06ih0p21aca9cz020fql2'>
            <column caption='24 month window' datatype='boolean' name='[Calculation_0343332865441792]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[start_date] &gt;= #2023-01-01# AND [start_date] &lt;= #2024-12-31#' />
