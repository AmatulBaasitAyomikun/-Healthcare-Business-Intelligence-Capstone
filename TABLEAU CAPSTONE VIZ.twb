    <worksheet name='Readmission rate per diagnosis'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#1b4f72' fontname='Tableau Semibold' fontsize='11'>Non-Small Cell Lung Carcinoma Has the Highest 30-Day Readmission Rate at 24.76%</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='vw_readmission_by_diagnosis (Hospital_data)' name='federated.12jruo61dbe0t21b2vbps08uhfou' />
          </datasources>
          <datasource-dependencies datasource='federated.12jruo61dbe0t21b2vbps08uhfou'>
            <column caption='readmission pct' datatype='real' name='[Calculation_1321349712875522]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[readmission_rate_pct] / 100' />
            </column>
            <column caption='Diagnosis short' datatype='string' name='[Calculation_1574237566619648]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [diagnosis] = &apos;Abnormal findings diagnostic imaging heart+coronary circulat (finding)&apos; THEN &apos;Abnormal Cardiac Imaging&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Acute myeloid leukemia (disorder)&apos; THEN &apos;Acute Myeloid Leukemia&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Acute non-ST segment elevation myocardial infarction (disorder)&apos; THEN &apos;Acute Non-ST MI&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Acute ST segment elevation myocardial infarction (disorder)&apos; THEN &apos;Acute ST MI&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Aortic valve regurgitation (disorder)&apos; THEN &apos;Aortic Valve Regurgitation&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Aortic valve stenosis (disorder)&apos; THEN &apos;Aortic Valve Stenosis&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Appendicitis (disorder)&apos; THEN &apos;Appendicitis&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Awaiting transplantation of bone marrow (situation)&apos; THEN &apos;Awaiting Bone Marrow Transplant&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Awaiting transplantation of kidney (situation)&apos; THEN &apos;Awaiting Kidney Transplant&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Chronic congestive heart failure (disorder)&apos; THEN &apos;Chronic Heart Failure&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Chronic obstructive bronchitis (disorder)&apos; THEN &apos;Chronic Obstructive Bronchitis&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Dependent drug abuse (disorder)&apos; THEN &apos;Dependent Drug Abuse&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;History of aortic valve replacement (situation)&apos; THEN &apos;History of Aortic Valve Replacement&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;History of artificial joint (situation)&apos; THEN &apos;History of Artificial Joint&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;History of coronary artery bypass grafting (situation)&apos; THEN &apos;History of CABG&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Injury of anterior cruciate ligament (disorder)&apos; THEN &apos;ACL Injury&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Injury of medial collateral ligament of knee (disorder)&apos; THEN &apos;MCL Injury&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Injury of tendon of the rotator cuff of shoulder (disorder)&apos; THEN &apos;Rotator Cuff Injury&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Leukemia  disease (disorder)&apos; THEN &apos;Leukemia&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Malignant neoplasm of breast (disorder)&apos; THEN &apos;Breast Cancer&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Malignant neoplasm of colon (disorder)&apos; THEN &apos;Colon Cancer&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Meningomyelocele (disorder)&apos; THEN &apos;Meningomyelocele&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Metastatic malignant neoplasm to colon (disorder)&apos; THEN &apos;Metastatic Colon Cancer&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Multiple myeloma (disorder)&apos; THEN &apos;Multiple Myeloma&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Neuropathy due to type 2 diabetes mellitus (disorder)&apos; THEN &apos;Diabetic Neuropathy&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Non-small cell carcinoma of lung  TNM stage 1 (disorder)&apos; THEN &apos;Non-Small Cell Lung Carcinoma&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Overlapping malignant neoplasm of colon (disorder)&apos; THEN &apos;Overlapping Colon Cancer&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Preinfarction syndrome (disorder)&apos; THEN &apos;Preinfarction Syndrome&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Primary malignant neoplasm of colon (disorder)&apos; THEN &apos;Primary Colon Cancer&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Pulmonary emphysema (disorder)&apos; THEN &apos;Pulmonary Emphysema&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Rupture of patellar tendon (disorder)&apos; THEN &apos;Patellar Tendon Rupture&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Sleep disorder (disorder)&apos; THEN &apos;Sleep Disorder&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Sterilization requested (situation)&apos; THEN &apos;Sterilization Requested&apos;&#13;&#10;ELSEIF [diagnosis] = &apos;Tubal pregnancy (disorder)&apos; THEN &apos;Tubal Pregnancy&apos;&#13;&#10;ELSE [diagnosis]&#13;&#10;END' />
            </column>
            <column caption='Diagnosis' datatype='string' name='[diagnosis]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1321349712875522]' derivation='None' name='[none:Calculation_1321349712875522:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1574237566619648]' derivation='None' name='[none:Calculation_1574237566619648:nk]' pivot='key' type='nominal' />
            <column caption='Readmission Rate Pct' datatype='real' name='[readmission_rate_pct]' role='measure' type='quantitative' />
